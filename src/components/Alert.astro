        <!-- Key Points PRE -->
        <div class="bg-black/20 rounded-sm p-4 my-6 border border-black/30 text-black" data-show-pre>
            <p class="text-base font-semibold mb-3">O que você precisa fazer agora:</p>
            <ul class="space-y-2 text-sm font-medium">
                <li>✓ Reúna documentos: Contrato, notificações, CRLV</li>
                <li>✓ Entre em contato HOJE — quanto mais cedo, mais opções você tem</li>
                <li>✓ Uma avaliação rápida mostra quais medidas ainda funcionam para sua situação</li>
            </ul>
        </div>

        <!-- Key Points POST -->
        <div class="bg-black/20 rounded-sm p-4 my-6 border border-black/30 text-black" data-show-post>
            <p class="text-base font-semibold mb-3">O que você precisa fazer URGENTEMENTE:</p>
            <ul class="space-y-2 text-sm font-medium">
                <li>✓ Reúna documentos: CRLV, contrato, comprovante de apreensão</li>
                <li>✓ Entre em contato AGORA — procure um advogado imediatamente</li>
                <li>✓ Uma avaliação rápida identifica opções legais e de negociação disponíveis</li>
            </ul>
        </div>

        <!-- CTA -->
