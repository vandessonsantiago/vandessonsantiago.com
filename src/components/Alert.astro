---
import whatsapp from "../../public/WhatsappLogo.svg"
import whatsappWhite from "../../public/WhatsappLogoWhite.svg"
---

<style>
    p {
        color: black;
    }
    ul li {
        color: white;
    }
    
    .timeline {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        margin: 2rem 0;
        position: relative;
    }
    
    .timeline-item {
        flex: 1;
        text-align: center;
        position: relative;
    }
    
    .timeline-dot {
        width: 2rem;
        height: 2rem;
        background: black;
        border: 3px solid white;
        border-radius: 50%;
        margin: 0 auto 0.75rem;
        font-weight: bold;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.875rem;
    }
    
    .timeline-label {
        color: black;
        font-weight: 600;
        font-size: 0.875rem;
    }
    
    .timeline-time {
        color: black;
        font-size: 0.75rem;
        opacity: 0.8;
    }
    
    @media (max-width: 640px) {
        .timeline {
            flex-direction: column;
            gap: 0.5rem;
        }
        
        .timeline-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            text-align: left;
        }
        
        .timeline-dot {
            flex-shrink: 0;
            margin: 0;
        }
    }
    
    .pulse {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    
    @keyframes pulse {
        0%, 100% {
            opacity: 1;
        }
        50% {
            opacity: 0.7;
        }
    }
</style>

<div class="bg-[#B9B4AB] p-6 md:p-8">
    <div class="max-w-6xl mx-auto px-4 md:px-14">
        <!-- Urgency Header -->
        <div class="flex items-start gap-3 mb-6">
            <div class="text-2xl">⚠️</div>
            <div>
                <p class="text-lg md:text-xl font-bold mb-2">Seu tempo é limitado</p>
                <p class="text-base font-semibold">Se o banco já notificou ou iniciou medidas, você pode ter apenas dias antes de ações irreversíveis.</p>
            </div>
        </div>

        <!-- Timeline Visual -->
        <div class="timeline">
            <div class="timeline-item">
                <div class="timeline-dot">1</div>
                <div class="timeline-label">HOJE</div>
                <div class="timeline-time">Notificação recebida</div>
            </div>
            <div class="timeline-item">
                <div class="timeline-dot">7d</div>
                <div class="timeline-label">DIA 7</div>
                <div class="timeline-time">Metade do prazo</div>
            </div>
            <div class="timeline-item">
                <div class="timeline-dot pulse">14d</div>
                <div class="timeline-label">DIA 14 ⏰</div>
                <div class="timeline-time">Apreensão possível</div>
            </div>
        </div>

        <!-- Key Points -->
        <div class="bg-black/20 rounded-sm p-4 my-6 border border-black/30">
            <p class="text-base font-semibold mb-3">O que você precisa fazer agora:</p>
            <ul class="space-y-2 text-sm font-medium">
                <li>✓ Reúna documentos: Contrato, notificações, CRLV</li>
                <li>✓ Entre em contato HOJE — cada dia reduz suas opções</li>
                <li>✓ Uma avaliação rápida mostra quais medidas ainda funcionam</li>
            </ul>
        </div>

        <!-- CTA -->
        <div class="flex justify-center">
            <a class="inline-flex w-full max-w-xs md:w-auto justify-center bg-black text-white px-6 py-3 md:px-8 md:py-3 rounded-sm items-center gap-2 transition transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-black font-bold" 
               href="https://wa.me/5592984093014?text=Ol%C3%A1%2C%20recebi%20notifica%C3%A7%C3%A3o%20do%20banco.%20Estou%20com%20pressa.%20Preciso%20de%20uma%20avalia%C3%A7%C3%A3o%20URGENTE." 
               aria-label="Avaliação urgente via WhatsApp">
                <img src={whatsappWhite.src} alt="WhatsApp" class="w-5 h-5" />
                <span>Avaliação Urgente Agora</span>
            </a>
        </div>
    </div>
</div>