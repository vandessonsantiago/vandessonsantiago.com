---
// HeroGate component: allows visitor to choose their situation (pre or post repossession)
// Then renders appropriate hero messaging
import imgHero from "../../public/imgHero.png"
import logo from "../../public/logo-vandessonsantiago.png"
const logoSrc = logo.src;
---

<div class="relative min-h-screen flex items-center justify-center bg-cover bg-center" style={`background-image: linear-gradient(rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.8)), url(${imgHero.src})`}>
  <div class="max-w-3xl mx-auto flex flex-col items-center justify-center gap-8 px-4 text-center">
    <div id="heroChoice" class="flex flex-col items-center justify-center gap-8 w-full">
      <div class="flex flex-col gap-4">
        <img src={logo.src} alt="Vandesson Santiago" class="mx-auto mb-8 w-64" />
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white">Seu carro ainda está com você ou o banco já tomou?</h1>
        <p class="text-base md:text-lg text-gray-300">Vamos adaptar a avaliação ao seu caso.</p>
      </div>

      <div class="flex flex-col md:flex-row gap-4 w-full md:w-auto">
        <button 
          type="button"
          onclick="showHero('pre')"
          class="flex-1 md:flex-initial px-6 py-3 md:px-6 md:py-3 bg-[#B9B4AB] text-black font-bold text-lg rounded-sm transition transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#B9B4AB] flex flex-col items-center justify-center gap-2"
        >
          <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2m1 15h-2v-2h2v2m0-4h-2V7h2v6z" fill="currentColor"/>
          </svg>
          <span class="leading-tight">Ainda estou com o carro</span>
          <span class="leading-tight text-base font-light">Quero saber se ainda dá tempo de evitar</span>
        </button>

        <button 
          type="button"
          onclick="showHero('post')"
          class="flex-1 md:flex-initial px-6 py-3 md:px-6 md:py-3 bg-white text-black font-bold text-lg rounded-sm transition transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-white flex flex-col items-center justify-center gap-2"
        >
          <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
            <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-5.04-6.71l-2.75 3.54-1.41-1.41L7 14h3V5h3v9h3l-3.04-3.71z" fill="currentColor"/>
          </svg>
          <span class="leading-tight">O banco já levou</span>
          <span class="leading-tight text-base font-light">Quero entender se ainda posso recuperar</span>
        </button>
      </div>
    </div>

    <div id="heroContent" class="w-full mt-8"></div>

    <!-- Scroll indicator - hidden by default, shown after selection -->
    <div id="scrollIndicator" class="absolute bottom-8 left-1/2 transform -translate-x-1/2 flex flex-col items-center gap-2 hidden opacity-0 transition-opacity duration-500">
      <p class="text-white text-sm font-semibold">Veja como funciona</p>
      <svg class="w-6 h-6 text-white animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </div>
</div>

<style>
  .hero-content {
    animation: fadeIn 0.5s ease-in;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script is:inline define:vars={{ logoSrc: logo.src }}>
  function showHero(scenario) {
    // Call global scenario setter from DefaultLayout
    if (typeof window.setScenario === 'function') {
      window.setScenario(scenario);
    }
    
    const contentDiv = document.getElementById('heroContent');
    const choiceDiv = document.getElementById('heroChoice');
    const siteContent = document.getElementById('siteContent');
    const scrollIndicator = document.getElementById('scrollIndicator');
    

    if (!contentDiv) return;

    if (choiceDiv) {
      choiceDiv.style.display = 'none';
    }

    if (siteContent) {
      siteContent.style.display = 'block';
    }

    // Show scroll indicator
    if (scrollIndicator) {
      scrollIndicator.classList.remove('hidden');
      scrollIndicator.classList.add('opacity-100');
      // Hide indicator after 6 seconds
      setTimeout(() => {
        scrollIndicator.classList.add('opacity-0', 'hidden');
      }, 6000);
    }

    if (scenario === 'pre') {
      contentDiv.innerHTML = `
        <div class="hero-content flex flex-col gap-4 text-center">
            <img src="${logoSrc}" alt="Logo" class="mx-auto mb-6 w-64" />
          <h2 class="text-2xl md:text-3xl font-bold text-white">
            Esperar reduz suas opções
          </h2>
          <p class="text-base md:text-lg text-gray-300 max-w-xl mx-auto">
            Uma avaliação rápida mostra qual é o prazo específico do seu contrato, opções de negociação com o banco e próximos passos. Quanto mais cedo você agir, melhor.
          </p>
          <div class="flex justify-center pt-4">
            <a 
              href="https://wa.me/5592984093014?text=Ol%C3%A1%2C%20recebi%20uma%20notifica%C3%A7%C3%A3o%20do%20banco.%20Quero%20avaliar%20minha%20situa%C3%A7%C3%A3o%20agora."
              class="inline-flex bg-[#B9B4AB] text-black px-6 py-3 rounded-sm items-center gap-2 font-bold transition transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#B9B4AB]"
              aria-label="Avaliar agora via WhatsApp"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                <path d="M21 11.5a9.38 9.38 0 0 1-1.06 4.25l.01.02c-.42 1.17-1.42 2.33-2.57 3.37-1.34 1.23-3.04 2.02-4.86 2.02A9.84 9.84 0 0 1 3 14.12C3 8.1 7.6 3.5 13.6 3.5c2.08 0 4.01.63 5.63 1.71.87.6 1.65 1.36 2.27 2.25.52.76.9 1.61 1.1 2.48.1.43.16.88.16 1.31v.15z" stroke="currentColor" stroke-width="0.6" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M17.2 14.1c-.3-.15-1.8-.9-2.07-1-.26-.09-.45-.14-.64.15-.2.28-.8 1-.98 1.2-.18.2-.36.23-.67.08-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.34.45-.51.15-.17.2-.3.3-.5.1-.2.05-.38-.02-.52-.07-.13-.64-1.56-.88-2.14-.23-.56-.47-.48-.64-.48-.17 0-.37 0-.57 0-.2 0-.52.07-.79.37-.28.31-1.06 1.03-1.06 2.5 0 1.47 1.09 2.9 1.24 3.1.15.2 2.14 3.26 5.18 4.58 3.04 1.32 3.04.88 3.59.83.55-.05 1.8-.73 2.05-1.44.26-.71.26-1.32.18-1.44-.07-.12-.26-.2-.56-.35z" fill="currentColor"/>
              </svg>
              <span>Avaliar agora</span>
            </a>
          </div>
        </div>
      `;
    } else if (scenario === 'post') {
      contentDiv.innerHTML = `
        <div class="hero-content flex flex-col gap-4 text-center">
            <img src="${logoSrc}" alt="Logo" class="mx-auto mb-6 w-64" />
          <h2 class="text-2xl md:text-3xl font-bold text-white">
            Ainda há medidas possíveis
          </h2>
          <p class="text-base md:text-lg text-gray-300 max-w-xl mx-auto">
            Após apreensão você tem pouco tempo para agir. Uma avaliação urgente mostra opções de negociação com o banco, defesa legal e próximos passos. Cada hora conta.
          </p>
          <div class="flex justify-center pt-4">
            <a 
              href="https://wa.me/5592984093014?text=Ol%C3%A1%2C%20meu%20ve%C3%ADculo%20foi%20apreendido.%20Preciso%20de%20uma%20avalia%C3%A7%C3%A3o%20URGENTE."
              class="inline-flex bg-red-600 text-white px-6 py-3 rounded-sm items-center gap-2 font-bold transition transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-600"
              aria-label="Solicitar avaliação urgente via WhatsApp"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                <path d="M21 11.5a9.38 9.38 0 0 1-1.06 4.25l.01.02c-.42 1.17-1.42 2.33-2.57 3.37-1.34 1.23-3.04 2.02-4.86 2.02A9.84 9.84 0 0 1 3 14.12C3 8.1 7.6 3.5 13.6 3.5c2.08 0 4.01.63 5.63 1.71.87.6 1.65 1.36 2.27 2.25.52.76.9 1.61 1.1 2.48.1.43.16.88.16 1.31v.15z" stroke="currentColor" stroke-width="0.6" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M17.2 14.1c-.3-.15-1.8-.9-2.07-1-.26-.09-.45-.14-.64.15-.2.28-.8 1-.98 1.2-.18.2-.36.23-.67.08-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.34.45-.51.15-.17.2-.3.3-.5.1-.2.05-.38-.02-.52-.07-.13-.64-1.56-.88-2.14-.23-.56-.47-.48-.64-.48-.17 0-.37 0-.57 0-.2 0-.52.07-.79.37-.28.31-1.06 1.03-1.06 2.5 0 1.47 1.09 2.9 1.24 3.1.15.2 2.14 3.26 5.18 4.58 3.04 1.32 3.04.88 3.59.83.55-.05 1.8-.73 2.05-1.44.26-.71.26-1.32.18-1.44-.07-.12-.26-.2-.56-.35z" fill="currentColor"/>
              </svg>
              <span>Avaliação URGENTE</span>
            </a>
          </div>
        </div>
      `;
    }

    setTimeout(() => {
      contentDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }, 100);
  }

  window.showHero = showHero;

  document.addEventListener('DOMContentLoaded', function () {
    const siteContent = document.getElementById('siteContent');
    if (siteContent) {
      siteContent.style.display = 'none';
    }
  });
</script>