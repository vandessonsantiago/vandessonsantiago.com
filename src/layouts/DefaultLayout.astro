---
import "../styles/global.css";
import whatsapp from "../../public/WhatsappLogo.svg";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Vandesson Santiago - Advogado</title>
	</head>
	<body>
		<slot></slot>

		<!-- Sticky WhatsApp button (mobile) -->
		<a href="https://wa.me/5592984093014?text=Ol%C3%A1%2C%20gostaria%20de%20uma%20avalia%C3%A7%C3%A3o%20inicial%20do%20meu%20caso" class="fixed bottom-6 right-4 md:hidden bg-[#25D366] p-3 rounded-full shadow-lg z-50 inline-flex items-center justify-center" aria-label="Abrir WhatsApp" title="Falar pelo WhatsApp">
			<img src={whatsapp.src} alt="WhatsApp" class="w-6 h-6" />
		</a>

		<!-- Global scenario tracker and adapter -->
		<script is:inline>
			(function() {
				// Initialize scenario tracking
				const SCENARIO_KEY = 'heroScenario';
				
				// Dispatch custom event when scenario changes
				function setScenario(scenario) {
					localStorage.setItem(SCENARIO_KEY, scenario);
					window.dispatchEvent(new CustomEvent('scenarioChanged', { detail: { scenario } }));
					updatePageForScenario(scenario);
				}
				
				function getScenario() {
					return localStorage.getItem(SCENARIO_KEY) || null;
				}
				
				function updatePageForScenario(scenario) {
					// Update all data attributes for conditional rendering
					document.documentElement.setAttribute('data-scenario', scenario);
					
					// Notify all scenario-aware components
					const components = document.querySelectorAll('[data-scenario-aware]');
					components.forEach(component => {
						component.setAttribute('data-current-scenario', scenario);
						// Trigger component update if it has a method
						if (typeof component.__updateScenario === 'function') {
							component.__updateScenario(scenario);
						}
					});
				}
				
				// Expose globally for HeroGate buttons
				window.setScenario = setScenario;
				window.getScenario = getScenario;
				
				// Initialize on load
				document.addEventListener('DOMContentLoaded', function() {
					const currentScenario = getScenario();
					if (currentScenario) {
						updatePageForScenario(currentScenario);
					}
				});
			})();
		</script>
	</body>
</html>
